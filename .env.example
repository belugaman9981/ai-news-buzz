# ── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Server ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Admin token (for /api/admin/refresh) ───────────────────
ADMIN_SECRET=replace-with-a-long-random-string

# Auto-refresh schedule (cron syntax) ────────────────────
# Every 24 hours at 6am = 0 6 * * *   |   Every 12 hours = 0 */12 * * *
REFRESH_CRON=0 6 * * *

# ── Rate limiting ──────────────────────────────────────────
RATE_LIMIT_MAX=120
