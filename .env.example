# ── News Fetching (NewsAPI) ────────────────────────────────
# Get a free key at https://newsapi.org
NEWS_API_KEY=your-newsapi-key-here

# ── AI Rewriting (Google Gemini) ───────────────────────────
# Get a free key at https://aistudio.google.com
GEMINI_API_KEY=your-gemini-api-key-here

# ── Server ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
APP_URL=https://your-app.onrender.com

# ── Admin token (for /api/admin/refresh) ───────────────────
ADMIN_SECRET=replace-with-a-long-random-string

# ── JWT (auth tokens) ──────────────────────────────────────
JWT_SECRET=replace-with-another-long-random-string

# ── Auto-refresh schedule (cron syntax) ────────────────────
# Every 24 hours at 6am = 0 6 * * *   |   Every 12 hours = 0 */12 * * *
REFRESH_CRON=0 6 * * *

# ── Stripe (optional — payments) ──────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PROMO_COUPON_ID=

# ── Gmail (optional — email newsletters) ──────────────────
# Use a Gmail App Password: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=your-app-password-here
