# ── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Server ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Admin token (for /api/admin/refresh) ───────────────────
ADMIN_SECRET=replace-with-a-long-random-string

# ── Auto-refresh schedule (cron syntax) ────────────────────
# Every 2 hours = 0 */2 * * *   |   Every 30 min = */30 * * * *
REFRESH_CRON=0 */2 * * *

# ── Rate limiting ──────────────────────────────────────────
RATE_LIMIT_MAX=120
